# GameAgentHub Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# GitLab OAuth Configuration
GITLAB_CLIENT_ID=your-gitlab-client-id
GITLAB_CLIENT_SECRET=your-gitlab-client-secret
GITLAB_REDIRECT_URI=http://localhost:3000/auth/gitlab/callback
GITLAB_API_URL=https://git.game.netease.com/api/v4
GITLAB_WEBHOOK_SECRET=your-webhook-secret

# Database Configuration (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/gameagenthub
# REDIS_URL=redis://localhost:6379

# GDI Scoring Configuration
GDI_PROMOTION_THRESHOLD=0.7
GDI_HIGH_QUALITY_THRESHOLD=0.85
GDI_FEATURED_THRESHOLD=0.9

# Security
JWT_SECRET=your-jwt-secret-key
SESSION_SECRET=your-session-secret

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log